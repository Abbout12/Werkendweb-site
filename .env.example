# Poort (standaard 3000)
PORT=3000

# Omgeving: development of production
NODE_ENV=development

# SMTP-instellingen voor e-mailversturing
# Gmail: gebruik een App Password (niet je gewone wachtwoord)
# Zie: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jouwemailadres@gmail.com
SMTP_PASS=jouw-app-wachtwoord

# E-mailadres dat de aanvragen ontvangt
CONTACT_EMAIL=info@werkendweb.nl

# Toegestane origin voor CORS (productie-URL van je website)
ALLOWED_ORIGIN=https://werkendweb.nl
